[*.{cs,vb}]
# For variables
dotnet_naming_symbols.local_symbol.applicable_kinds = local, field
dotnet_naming_style.local_style.capitalization = pascal_case
dotnet_naming_rule.variables_are_camel_case.severity = warning
# dotnet_naming_rule.variables_are_camel_case.symbols = local_symbol
dotnet_naming_rule.variables_are_camel_case.style = snake_all_upper

# 变量命名不需加类型前缀，小驼峰命名
dotnet_naming_symbols.parameter_symbol.applicable_kinds = local, parameter
dotnet_naming_rule.parameters_are_camel_case.severity = warning
dotnet_naming_rule.parameters_are_camel_case.symbols = parameter_symbol
dotnet_naming_rule.parameters_are_camel_case.style = no_prefix_pascal_case
dotnet_naming_style.no_prefix_pascal_case.capitalization = camel_case

# private/protected成员变量使用_作为前缀，后接小驼峰变量名
dotnet_naming_symbols.internal_private_protected_parameters.applicable_kinds = field
dotnet_naming_symbols.internal_private_protected_parameters.applicable_accessibilities = private, protected

dotnet_naming_style.start_with___camel_case.required_prefix = _
dotnet_naming_style.start_with___camel_case.capitalization = camel_case

dotnet_naming_rule.internal_parameters_start_with___camel_case.symbols = internal_private_protected_parameters
dotnet_naming_rule.internal_parameters_start_with___camel_case.style = start_with___camel_case
dotnet_naming_rule.internal_parameters_start_with___camel_case.severity = warning

# public大驼峰命名。 
dotnet_naming_symbols.internal_public_parameters.applicable_kinds = field
dotnet_naming_symbols.internal_public_parameters.applicable_accessibilities = public
dotnet_naming_symbols.internal_public_parameters.required_modifiers = *

dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_rule.internal_parameters_pascal_case.symbols = internal_public_parameters
dotnet_naming_rule.internal_parameters_pascal_case.style = pascal_case
dotnet_naming_rule.internal_parameters_pascal_case.severity = warning

# 常量使用c_作为前缀,后接大驼峰命名
dotnet_naming_symbols.const_parameters.applicable_kinds = local, field
dotnet_naming_symbols.const_parameters.applicable_accessibilities = *
dotnet_naming_symbols.const_parameters.required_modifiers = const

dotnet_naming_style.start_with_c__pascal_case.required_prefix = c_
dotnet_naming_style.start_with_c__pascal_case.capitalization = pascal_case

dotnet_naming_rule.const_parameters_pascal_start_with_c__pascal_case.symbols = const_parameters
dotnet_naming_rule.const_parameters_pascal_start_with_c__pascal_case.style = start_with_c__pascal_case
dotnet_naming_rule.const_parameters_pascal_start_with_c__pascal_case.severity = warning

# 静态成员变量使用s_作为前缀，private/protected后接小驼峰变量名
dotnet_naming_symbols.static_private_protected_parameters.applicable_kinds = field
dotnet_naming_symbols.static_private_protected_parameters.applicable_accessibilities = private, protected
dotnet_naming_symbols.static_private_protected_parameters.required_modifiers = static 

dotnet_naming_style.start_with_s_camel_case.required_prefix = s_
dotnet_naming_style.start_with_s_camel_case.capitalization = camel_case

dotnet_naming_rule.static_parameters_start_with_s_camel_case.symbols = static_private_protected_parameters
dotnet_naming_rule.static_parameters_start_with_s_camel_case.style = start_with_s_camel_case
dotnet_naming_rule.static_parameters_start_with_s_camel_case.severity = warning

#静态成员变量使 public大驼峰命名。 
dotnet_naming_symbols.static_public_parameters.applicable_kinds = field
dotnet_naming_symbols.static_public_parameters.applicable_accessibilities = public
dotnet_naming_symbols.static_public_parameters.required_modifiers = static 

dotnet_naming_style.start_with_s_pascal_case.required_prefix = s_
dotnet_naming_style.start_with_s_pascal_case.capitalization = pascal_case

dotnet_naming_rule.static_public_parameters_start_with_s_pascal_case.symbols = static_public_parameters
dotnet_naming_rule.static_public_parameters_start_with_s_pascal_case.style = start_with_s_pascal_case
dotnet_naming_rule.static_public_parameters_start_with_s_pascal_case.severity = warning

# 类、结构体大驼峰命名，命名与功能相符
dotnet_naming_symbols.class_struct.applicable_kinds = class, struct
dotnet_naming_symbols.class_struct.applicable_accessibilities = *

#dotnet_naming_style.class_struct_pascal_case_style.required_prefix = 
dotnet_naming_style.class_struct_pascal_case_style.capitalization = pascal_case

dotnet_naming_rule.class_struct_pascal_case.symbols = class_struct
dotnet_naming_rule.class_struct_pascal_case.style = class_struct_pascal_case_style
dotnet_naming_rule.class_struct_pascal_case.severity = warning

# 枚举类型及其枚举值，皆为大驼峰命名。 
dotnet_naming_symbols.enum.applicable_kinds = enum
dotnet_naming_symbols.enum.applicable_accessibilities = *

#dotnet_naming_style.class_struct_pascal_case_style.required_prefix = 
dotnet_naming_style.enum_case_style.capitalization = pascal_case

dotnet_naming_rule.class_struct_pascal_case.symbols = enum
dotnet_naming_rule.class_struct_pascal_case.style = pascal_case
dotnet_naming_rule.class_struct_pascal_case.severity = warning

# 宏大写蛇形式命名？？


# 函数大驼峰命名，命名与功能相符； 公共属性（Property）读/写大驼峰命名。
dotnet_naming_symbols.method.applicable_kinds = method, property
dotnet_naming_symbols.method.applicable_accessibilities = *

dotnet_naming_style.method_pascal_case.required_prefix = 
dotnet_naming_style.method_pascal_case.required_suffix = 
dotnet_naming_style.method_pascal_case.capitalization = pascal_case
dotnet_naming_rule.method_pascal_case.symbols = method
dotnet_naming_rule.method_pascal_case.style = pascal_case
dotnet_naming_rule.method_pascal_case.severity = warning

# 接口以大写字母I（Interface）开头，后接大驼峰命名。 
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_style.start_with_I_pascal_case.required_prefix = I
dotnet_naming_style.start_with_I_pascal_case.capitalization = pascal_case

dotnet_naming_rule.interface_start_with_I_pascal_case.symbols = interface
dotnet_naming_rule.interface_start_with_i_pascal_case.style = start_with_I_pascal_case
dotnet_naming_rule.interface_start_with_i_pascal_case.severity = warning

end_of_line = lf
# Sort using and Import directives with System.* appearing first
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
# Avoid "this." and "Me." if not necessary
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_event = false:refactoring

# Use language keywords instead of framework type names for type references
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# Suggest more modern language features when available
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_explicit_tuple_names = true:suggestion

# Whitespace options
dotnet_style_allow_multiple_blank_lines_experimental = false


dotnet_diagnostic.IDE1006.severity = warning


[*.cs]
# Newline settings
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Indentation preferences
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left

# Whitespace options
csharp_style_allow_embedded_statements_on_same_line_experimental = false
csharp_style_allow_blank_lines_between_consecutive_braces_experimental = false
csharp_style_allow_blank_line_after_colon_in_constructor_initializer_experimental = false
csharp_style_allow_blank_line_after_token_in_conditional_expression_experimental = false
csharp_style_allow_blank_line_after_token_in_arrow_expression_clause_experimental = false

# Prefer method-like constructs to have a block body
csharp_style_expression_bodied_methods = false:none
csharp_style_expression_bodied_constructors = false:none
csharp_style_expression_bodied_operators = false:none

# Prefer property-like constructs to have an expression-body
csharp_style_expression_bodied_properties = true:none
csharp_style_expression_bodied_indexers = true:none
csharp_style_expression_bodied_accessors = true:none

# Suggest more modern language features when available
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion
csharp_style_prefer_extended_property_pattern = true:suggestion

# Space preferences
csharp_space_after_cast = false
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_after_comma = true
csharp_space_after_dot = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_after_semicolon_in_for_statement = true
csharp_space_around_binary_operators = before_and_after
csharp_space_around_declaration_statements = do_not_ignore
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_before_comma = false
csharp_space_before_dot = false
csharp_space_before_open_square_brackets = false
csharp_space_before_semicolon_in_for_statement = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_between_square_brackets = false

# Blocks are allowed
csharp_prefer_braces = true:silent
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = true

# IDE0060: Remove unused parameter
dotnet_diagnostic.IDE0060.severity = suggestion
csharp_using_directive_placement = outside_namespace:silent
csharp_style_expression_bodied_lambdas = true:silent
csharp_style_expression_bodied_local_functions = false:silent

# IDE0007 : var' preferences
dotnet_diagnostic.IDE0007.severity = do_not_show
# dotnet_diagnostic.IDE0008.severity = suggestion

# IDE0011: Add braces
# csharp_prefer_braces = when_multiline:warning
# NOTE: We need the below severity entry for Add Braces due to https://github.com/dotnet/roslyn/issues/44201
# dotnet_diagnostic.IDE0011.severity = warning

# IDE0040: Add accessibility modifiers
# dotnet_diagnostic.IDE0040.severity = warning

# IDE0052: Remove unread private member
# dotnet_diagnostic.IDE0052.severity = warning

# IDE0059: Unnecessary assignment to a value
# dotnet_diagnostic.IDE0059.severity = warning

# CA1012: Abstract types should not have public constructors
# dotnet_diagnostic.CA1012.severity = warning

# CA1822: Make member static
# dotnet_diagnostic.CA1822.severity = warning

# Prefer "var" everywhere
# dotnet_diagnostic.IDE0007.severity = warning
# csharp_style_var_for_built_in_types = true:warning
# csharp_style_var_when_type_is_apparent = true:warning
# csharp_style_var_elsewhere = true:warning

# csharp_style_allow_embedded_statements_on_same_line_experimental
# dotnet_diagnostic.IDE2001.severity = warning

# csharp_style_allow_blank_lines_between_consecutive_braces_experimental
# dotnet_diagnostic.IDE2002.severity = warning

# csharp_style_allow_blank_line_after_colon_in_constructor_initializer_experimental
# dotnet_diagnostic.IDE2004.severity = warning

# csharp_style_allow_blank_line_after_token_in_conditional_expression_experimental
# dotnet_diagnostic.IDE2005.severity = warning

# csharp_style_allow_blank_line_after_token_in_arrow_expression_clause_experimental
# dotnet_diagnostic.IDE2006.severity = warning